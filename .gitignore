# macOS / editor noise
.DS_Store
*.swp
*~

# Build output (root-level binary only — NOT the cmd/isotopo source dir)
/isotopo
/cmd/isotopo/isotopo

# Local dev temp files
/tmp/

# Diagnostic files emitted by golden tests on failure
samples/*/*/actual.svg
.playwright-mcp/
/gen-docs
/isotopo-mcp
/cmd/isotopo-mcp/isotopo-mcp
/tools/gen-docs/gen-docs
tools/visreg/baselines/*.actual.png
.claude/
test-results/

# scratch playground (screenshots, experiments) — not repo content
samples/playground/
/visreg

# style_refer render artifacts (regenerable)
samples/style_refer/_out/

# scratch experiment dir (dev throwaway)
samples/playground_tmp/

# render output dirs at repo root (regenerable via `isotopo render <in> <out>`)
/out/
/out-*/
dist/
