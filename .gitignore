.claude/
test-results/

# scratch playground (screenshots, experiments) — not repo content
samples/playground/
/visreg

# playbook style-swatch render artifacts (regenerable)
samples/playbook/styles/_swatch/out_*/

# style_refer render artifacts (regenerable)
samples/style_refer/_out/
