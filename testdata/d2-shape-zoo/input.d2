# Shape zoo — every d2 shape the catalog maps, all in one .d2 source.
# Renders to verify that auto-layout + the expanded mapD2Shape behave
# sensibly across the full d2 vocabulary.

rect: Rectangle { shape: rectangle }
sq:   Square    { shape: square }
page: Page      { shape: page }
doc:  Document  { shape: document }
code: Code      { shape: code }
text: Text      { shape: text }
# image shape requires an icon URL in d2; skip it from the zoo to keep
# the example pure-DSL — icon embedding is handled separately.

cyl:  Cylinder  { shape: cylinder }
q:    Queue     { shape: queue }
sd:   StoredData { shape: stored_data }

circ: Circle    { shape: circle }
oval: Oval      { shape: oval }
diamd: Diamond  { shape: diamond }
hex:  Hexagon   { shape: hexagon }
para: Parallelogram { shape: parallelogram }
step: Step      { shape: step }

p1:   Person    { shape: person }
p2:   C4 Person { shape: c4-person }

cloud: Cloud    { shape: cloud }

cls:  Class     { shape: class }
tbl:  SQL Table { shape: sql_table }

# A few connections so the layout doesn't degenerate to columns.
rect -> cyl: holds
cyl -> circ
circ -> cloud
diamd -> hex
p1 -> rect
text -> code
