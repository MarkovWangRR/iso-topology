# d2 nested containers → iso group, automatic.
#
# The d2 source uses `cluster: { ... }` and `wn1: { ... }` blocks to
# express hierarchy. With Step 4 in place, every container shows up as
# a translucent iso panel and its children sit on top — no YAML, no
# manual offsets. Agent-friendly: write graph hierarchy, get iso scene.

cluster: Kubernetes Cluster {
  wn1: Worker Node 1 {
    proxy1: LiteLLM Proxy
    cache1: Cache {
      shape: cylinder
    }
  }
  wn2: Worker Node 2 {
    proxy2: LiteLLM Proxy
    cache2: Cache {
      shape: cylinder
    }
  }
  ingress: Ingress Controller
}

users: Users {
  shape: person
}

openai: OpenAI
anthropic: Anthropic

users -> cluster.ingress: request
cluster.ingress -> cluster.wn1.proxy1
cluster.ingress -> cluster.wn2.proxy2
cluster.wn1.proxy1 -> openai
cluster.wn2.proxy2 -> anthropic
